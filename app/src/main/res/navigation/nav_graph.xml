<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.login.LoginFragment"
        android:label="LoginFragment">

        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_forgetPasswordFragment"
            app:destination="@id/forgetPasswordFragment" />
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.register.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.home.HomeFragment"
        android:label="HomeFragment"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_trendingFragment"
            app:destination="@id/trendingFragment" />
        <action
            android:id="@+id/action_homeFragment_to_categoryFragment"
            app:destination="@id/categoryFragment" />
        <action
            android:id="@+id/action_homeFragment_to_detailsFragment"
            app:destination="@id/detailsFragment" />
        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_homeFragment_to_mySelfFragment"
            app:destination="@id/mySelfFragment" />
        <action
            android:id="@+id/action_homeFragment_to_mySelfFragment2"
            app:destination="@id/mySelfFragment" />

    </fragment>
    <fragment
        android:id="@+id/detailsFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.details.DetailsFragment"
        android:label="DetailsFragment"
        tools:layout="@layout/fragment_details">

        <argument
            android:name="bookId"
            app:argType="string"
            app:nullable="true" />

        <action
            android:id="@+id/action_detailsFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_detailsFragment_to_mySelfFragment"
            app:destination="@id/mySelfFragment" />
    </fragment>
    <fragment
        android:id="@+id/forgetPasswordFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.forgetPasword.ForgetPasswordFragment"
        android:label="ForgetPasswordFragment">
        <action
            android:id="@+id/action_forgetPasswordFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/trendingFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.trending.TrendingFragment"
        android:label="fragment_trending"
        tools:layout="@layout/fragment_trending">
        <action
            android:id="@+id/action_trendingFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_trendingFragment_to_mySelfFragment"
            app:destination="@id/mySelfFragment" />
        <action
            android:id="@+id/action_trendingFragment_to_detailsFragment"
            app:destination="@id/detailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.category.CategoryFragment"
        android:label="fragment_category"
        tools:layout="@layout/fragment_category">

        <action
            android:id="@+id/action_categoryFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_categoryFragment_to_mySelfFragment"
            app:destination="@id/mySelfFragment" />
        <action
            android:id="@+id/action_categoryFragment_to_detailsFragment"
            app:destination="@id/detailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.profile.ProfileFragment"
        android:label="fragment_profile"
        tools:layout="@layout/fragment_profile" />
    <fragment
        android:id="@+id/mySelfFragment"
        android:name="com.doaa.mosalam.librarymanagementsystem.ui.mySelf.MySelfFragment"
        android:label="fragment_my_self"
        tools:layout="@layout/fragment_my_self">
        <action
            android:id="@+id/action_mySelfFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>
</navigation>