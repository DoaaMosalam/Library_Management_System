<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/light_cream"
        android:fillViewport="true"
        tools:context=".ui.mySelf.MySelfFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <include
                    android:id="@+id/commonHeader"
                    layout="@layout/layout_common_header" />

                <!-- Title -->
                <TextView
                    android:id="@+id/tvMyShelfTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/myshelf"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="4dp" />

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvMyShelfSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/manage_your_reading_journey"
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginBottom="16dp" />

                <!-- Tabs -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginBottom="16dp"
                    app:tabIndicatorColor="@android:color/white"
                    app:tabSelectedTextColor="@color/black"
                    app:tabTextColor="@color/peach_beige"
                    app:tabBackground="@drawable/bg_pill_primary"
                    app:tabMode="fixed"
                    app:tabGravity="fill">

                    <com.google.android.material.tabs.TabItem
                        android:id="@+id/tabAllBooks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/_5dp"
                        android:text="@string/all_books" />

                    <com.google.android.material.tabs.TabItem
                        android:id="@+id/tabCurrentlyReading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/currently_reading" />

                    <com.google.android.material.tabs.TabItem
                        android:id="@+id/tabRented"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rented" />

                    <com.google.android.material.tabs.TabItem
                        android:id="@+id/tabFinished"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/finished" />

                </com.google.android.material.tabs.TabLayout>
                <!--                <androidx.viewpager2.widget.ViewPager2-->
                <!--                    android:id="@+id/viewPager"-->
                <!--                    android:layout_width="match_parent"-->
                <!--                    android:layout_height="0dp"-->
                <!--                    android:layout_weight="1"/>-->
                <!-- Book Grid -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFVBooks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingBottom="8dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="3"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>


</layout>