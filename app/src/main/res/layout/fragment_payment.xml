<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/light_cream"
        tools:context=".ui.payment.PaymentFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5dp">

            <LinearLayout
                android:id="@+id/mainLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <!--Progress Bar-->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressIndicator"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    app:indicatorSize="48dp"
                    app:indicatorColor="@color/blue"
                    app:trackThickness="6dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Common Header -->
                <include
                    layout="@layout/layout_common_header"
                    android:id="@+id/commonHeader" />

                <!-- Payment Method Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/baseline_credit_card_24" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/credit_debit_card_nvisa_4242"
                            android:textSize="16sp"
                            android:textColor="@color/black" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Invoice Summary Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:text="@string/invoice_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvOutstandingBalance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/outstanding_balance_12_97"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvPendingPayments"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/pending_payments_2"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvPaymentMethod"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_method_credit_card"
                            android:textSize="16sp"
                            android:textColor="@color/ochre_burnt_orange" />

                        <TextView
                            android:id="@+id/tvAmountToPay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/amount_to_pay_12_97"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/ochre_burnt_orange"
                            android:layout_marginTop="8dp" />

                        <Button
                            android:id="@+id/btnPayNow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:text="@string/pay_now"
                            android:backgroundTint="@color/ochre_burnt_orange"
                            android:textColor="@color/white"
                            android:layout_marginTop="12dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Rental History Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:text="@string/rental_history"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:layout_marginBottom="12dp" />

                        <TableLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="0,1,2,3">

                            <!-- Header -->
                            <TableRow>

                                <TextView
                                    android:text="@string/book"
                                    android:textStyle="bold" />

                                <TextView
                                    android:text="@string/date_rented"
                                    android:textStyle="bold" />

                                <TextView
                                    android:text="@string/amount"
                                    android:textStyle="bold" />

                                <TextView
                                    android:text="@string/status"
                                    android:textStyle="bold" />
                            </TableRow>

                            <!-- Example Row -->
                            <TableRow>

                                <TextView android:text="@string/bookname" />

                                <TextView android:text="@string/oct_15_2023" />

                                <TextView
                                    android:text="@string/_4_99"
                                    android:textStyle="bold" />

                                <TextView
                                    android:text="@string/pending"
                                    android:textColor="@color/ochre_burnt_orange" />
                            </TableRow>

                        </TableLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</layout>
